KALSHI_API_KEY_ID=YOUR_KALSHI_API_KEY_ID
KALSHI_PRIVATE_KEY_PATH=./kalshi-key.txt

ROBINHOOD_API_KEY=YOUR_ROBINHOOD_API_KEY
ROBINHOOD_PRIVATE_KEY_PATH=~/.ssh/rh_privatekey
ROBINHOOD_ACCOUNT_NUMBER=YOUR_ROBINHOOD_ACCOUNT_NUMBER

# Optional overrides
# KALSHI_OUTPUT_FORMAT=reconciliation
# KALSHI_TIMEOUT_SECONDS=10
# KALSHI_PAGE_LIMIT=100
# KALSHI_FULL_HISTORY=false
# KALSHI_STARTING_CASH=100
# KALSHI_ENABLE_CACHE=false
# KALSHI_CACHE_FILE=./.kalshi_cache.json
# ROBINHOOD_API_VERSION=v2
# ROBINHOOD_RESOURCE=accounts
# ROBINHOOD_OUTPUT_FORMAT=json
# ROBINHOOD_CREATED_AT_START=2024-01-01T00:00:00Z
